#!/usr/bin/env bash
# OpenAirLLM By EdgeSearch — launcher script
# Starts the Rust bridge server and the OpenAirLLM frontend (OpenClaude fork)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
AIRLLM_ROOT="$(cd "$PROJECT_ROOT/.." && pwd)"

# Config
BRIDGE_ADDR="${AIRLLM_BRIDGE_ADDR:-127.0.0.1:18080}"
OLLAMA_URL="${OLLAMA_BASE_URL:-http://localhost:11434}"
DEFAULT_MODEL="${OPENAI_MODEL:-qwen3.5:4b}"

# Colors
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}OpenAirLLM By EdgeSearch${NC}"
echo -e "${GREEN}Starting bridge server at ${BRIDGE_ADDR}...${NC}"

# Start the Rust bridge in background
export OLLAMA_BASE_URL="$OLLAMA_URL"
export AIRLLM_BRIDGE_ADDR="$BRIDGE_ADDR"
# Keep model loaded for 24h to avoid reload latency (default is 5min)
export OLLAMA_KEEP_ALIVE="24h"
"$AIRLLM_ROOT/target/release/bridge" &
BRIDGE_PID=$!

# Wait for bridge to be ready
sleep 2

# Check if bridge is running
if ! kill -0 $BRIDGE_PID 2>/dev/null; then
    echo "Error: Bridge server failed to start"
    exit 1
fi

echo -e "${GREEN}Bridge is ready. Pre-warming model...${NC}"

# Pre-warm the model so the first user request is fast
curl -s http://localhost:11434/api/chat -d "{\"model\":\"$DEFAULT_MODEL\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}],\"stream\":false}" > /dev/null 2>&1 &
PREWARM_PID=$!

echo -e "${GREEN}Starting frontend...${NC}"

# Configure the frontend to use our bridge as the OpenAI-compatible endpoint
export CLAUDE_CODE_USE_OPENAI=1
export OPENAI_BASE_URL="http://${BRIDGE_ADDR}/v1"
export OPENAI_MODEL="$DEFAULT_MODEL"

# Use simple system prompt for local models (avoids 3000+ token system prompt
# that kills performance on small models like qwen3.5:4b)
export CLAUDE_CODE_SIMPLE=1

# Force all requests (including background/title/summary) to use the same
# fast model. Without this, the frontend makes parallel calls with the
# heavy default model (qwen2.5-coder:14b = 90s per call).
export AIRLLM_FORCE_MODEL="$DEFAULT_MODEL"

# Start the frontend with bypass permissions so it can create files
# without prompting the user on every tool call.
node "$SCRIPT_DIR/openairllm" --dangerously-skip-permissions "$@"

# Cleanup: kill bridge when frontend exits
kill $BRIDGE_PID 2>/dev/null || true